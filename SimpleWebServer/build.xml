  <!-- Provide name for the project, and path for the files-->
  <project name="SimpleWebServer" default="package">

       <target name="ant">
  	    <mkdir dir="build/classes" />                      
  	    <mkdir dir="www" />                                       
  	  </target>

  	  <target name="compile" depends="ant" description="Compile Java code">
  	    <javac srcdir="src" destdir="build/classes" includeAntRuntime = "false"/>
  	  </target>

  	  <target name="package" depends="compile" description="Compile Test">                                                
  	    <jar destfile="www/SimpleWebServer.jar" basedir="build/classes"/>
  	  </target>

  	  <target name="clean" description="Deletes generated directories">
  	    <delete dir="build" />
  	    <delete dir="www" />
  	  </target>

  	</project>
