  <!-- Provide name for the project, and path for the files-->
  <project name="SimpleWebServer" default="package">

	  <target name="init">
	    <mkdir dir="build/classes" />                      
	    <mkdir dir="dist" />                                       
	  </target>

	  <target name="compile" depends="init" description="Compile Java code">
	    <javac srcdir="src" destdir="build/classes"/>
	  </target>

	  <target name="package" depends="compile" description="Generate JAR file">                                                
	    <jar destfile="dist/SimpleWebServer.jar" basedir="build/classes"/>
	  </target>

	  <target name="clean" description="Deletes generated directories">
	    <delete dir="build" />
	    <delete dir="dist" />
	  </target>

	</project>
